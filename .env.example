GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here
COGNEE_API_KEY=your-cognee-cloud-pro-api-key-here
COGNEE_TENANT_ID=your-cognee-tenant-id-here
# Must be your tenant-specific subdomain (see Cognee Cloud dashboard → Settings → API)
COGNEE_API_BASE=https://tenant-<YOUR_TENANT_ID>.aws.cognee.ai

# AI Client Configuration
AI_QUOTA_COOLDOWN=60
AI_GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-lite,gemini-1.5-flash
